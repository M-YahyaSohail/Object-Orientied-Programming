    void verifyIdentity(string c) { if(cnic == c) isVerified = true; }
    void boostAd() { if(isVerified) cout << "Boosted.\n"; }
    void processSale() { totalSold++; }
    void calculateRevenue() const { cout << "Revenue calculated.\n"; }
};

class Listing {
private:
    static int activeListings;
    int listingID;
    Vehicle car;
    double price;
    bool isActive;
    Seller* owner;

public:
    Listing() : listingID(0), price(0.0), isActive(false), owner(nullptr) {}
    Listing(int id, Vehicle v, double p, Seller* o) : listingID(id), car(v), price(p), isActive(true), owner(o) {
        activeListings++;
    }
    Listing(const Listing& other) {
        listingID = other.listingID;
        car = other.car;
        price = other.price;
        isActive = other.isActive;
        owner = other.owner; 
    }

    static int getActiveCount() { return activeListings; }

    int getListingID() const { return listingID; }
    Vehicle getCar() const { return car; }
    double getPrice() const { return price; }
    bool getIsActive() const { return isActive; }
    Seller* getOwner() const { return owner; }
    
    void setPrice(double p) { price = p; }
    void setIsActive(bool status) { isActive = status; }

    void activate() { isActive = true; activeListings++; }
    void deactivate() { isActive = false; activeListings--; }
    void applyDiscount(double percent) { price *= (1.0 - percent); }
    void displayListing() const { if(isActive) { cout << "ID " << listingID << " | PKR " << price << "\n"; car.displaySpecs(); } }
};
int Listing::activeListings = 0;

class Buyer : public User {
private:
    const int MAX_FAVS; // CONST MEMBER 1
    double budget;
    Message outbox[10];
    int msgCount;
    Listing favs[5];
    int favCount;

public:
    Buyer() : MAX_FAVS(5), budget(0.0), msgCount(0), favCount(0) {}
    Buyer(string id, string n, string e, string p, Location l, double b) : User(id, n, e, p, l), MAX_FAVS(5), budget(b), msgCount(0), favCount(0) {}

    double getBudget() const { return budget; }
    void setBudget(double b) { budget = b; }

    void saveFavorite(const Listing& l) { if(favCount < MAX_FAVS) favs[favCount++] = l; }
    void removeFavorite() { if(favCount > 0) favCount--; }
    void sendMessage(Message m) { if(msgCount < 10) outbox[msgCount++] = m; }
    void viewFavorites() const { cout << "Saved: " << favCount << "\n"; }
};

class Admin : public User {
private:
    const int MAX_REPORTS; // CONST MEMBER 2
    const string MASTER_CODE; // CONST MEMBER 3
    int adminLevel;
    int reportsHandled;
    string shift;

public:
    Admin() : MAX_REPORTS(100), MASTER_CODE("ADM-XYZ"), adminLevel(1), reportsHandled(0) {}
    Admin(string id, string n, string e, string p, Location l, int level, string sh, string code)
        : User(id, n, e, p, l), MAX_REPORTS(100), MASTER_CODE(code), adminLevel(level), reportsHandled(0), shift(sh) {}

    int getAdminLevel() const { return adminLevel; }
    void setAdminLevel(int l) { adminLevel = l; }

    void approveListing(Listing& l) { l.setIsActive(true); reportsHandled++; }
    void removeListing(Listing& l) { l.setIsActive(false); }
    void banUser(User& u) { u.setEmail("BANNED"); }
    void generateReport() const { cout << "Reports: " << reportsHandled << "\n"; }
};

class Marketplace {
private:
    static int totalVisits;
    const char* const platformName; // CONST MEMBER 4 & CONST POINTER
    const int SYSTEM_CAPACITY; // CONST MEMBER 5
    Listing allAds[100];
    int adCount;
    User* users[50];
    int userCount;

public:
    Marketplace() : platformName("PakWheels_Clone"), SYSTEM_CAPACITY(100), adCount(0), userCount(0) {}

    static int getPlatformVisits() { return totalVisits; }

    int getAdCount() const { return adCount; }
    void setAdCount(int c) { adCount = c; }

    void addListing(Listing l) { if(adCount < SYSTEM_CAPACITY) allAds[adCount++] = l; }
    
    void updateListingPrice(int id, double newPrice) {
        for(int i = 0; i < adCount; i++) {
            if(allAds[i].getListingID() == id) { allAds[i].setPrice(newPrice); return; }
        }
    }
    
    void deleteListing(int id) {
        for(int i = 0; i < adCount; i++) {
            if(allAds[i].getListingID() == id) { allAds[i].setIsActive(false); return; }
        }
    }
    
    void filterVehicles(string b, string m, double p, int y, int mil) const {
        for(int i = 0; i < adCount; i++) {
            if(allAds[i].getIsActive() && 
               allAds[i].getCar().getMake() == b && 
               allAds[i].getCar().getModel() == m && 
               allAds[i].getPrice() <= p && 
               allAds[i].getCar().getYear() >= y && 
               allAds[i].getCar().getMileage() <= mil) {
                allAds[i].displayListing();
            }
        }
    }
};
int Marketplace::totalVisits = 0;

