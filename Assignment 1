#include <iostream>
#include <string>

using namespace std;

class Location {
private:
    string city;
    string area;
    string zipCode;
    double latitude;
    double longitude;

public:
    Location() : city(""), area(""), zipCode(""), latitude(0.0), longitude(0.0) {}
    Location(string c, string a, string z, double lat, double lon) : city(c), area(a), zipCode(z), latitude(lat), longitude(lon) {}
    
    string getCity() const { return city; }
    void setCity(string c) { city = c; }

    void updateCoordinates(double newLat, double newLon) { latitude = newLat; longitude = newLon; }
    void calculateDistance() const { cout << "Calculating routing...\n"; }
    void verifyServiceZone() const { if (city == "Karachi") cout << "Active zone.\n"; }
    void displayMapPin() const { cout << "Pin: " << latitude << ", " << longitude << "\n"; }
};

class Engine {
private:
    string fuelStandard; // Removed const to allow assignment
    string engineNumber;
    int cc;
    string transmission;
    bool isHybrid;

public:
    Engine() : fuelStandard("Euro-2"), engineNumber(""), cc(0), transmission(""), isHybrid(false) {}
    Engine(string std, string eNum, int c, string t, bool h) : fuelStandard(std), engineNumber(eNum), cc(c), transmission(t), isHybrid(h) {}
    
    int getCC() const { return cc; }
    void setCC(int c) { cc = c; }

    void startEngine() const { cout << "Engine started.\n"; }
    void stopEngine() const { cout << "Engine off.\n"; }
    void diagnose() const { cout << fuelStandard << " diagnostics passed.\n"; }
    void service() { cout << "Maintenance done.\n"; }
};

class Vehicle {
private:
    string VIN; // Removed const to allow assignment
    string make;
    string model;
    int year;
    int mileage;
    Engine carEngine;

public:
    Vehicle() : VIN("UNKNOWN"), make(""), model(""), year(0), mileage(0) {}
    Vehicle(string v, string mk, string md, int y, int mil, Engine e) : VIN(v), make(mk), model(md), year(y), mileage(mil), carEngine(e) {}
    
    string getMake() const { return make; }
    string getModel() const { return model; }
    int getYear() const { return year; }
    int getMileage() const { return mileage; }
    void setMileage(int m) { mileage = m; }

    void driveTrip(int miles) { mileage += miles; }
    void calculateDepreciation() const { cout << "Depreciated.\n"; }
    void displaySpecs() const { cout << year << " " << make << " " << model << " - " << mileage << "km\n"; }
    bool isVintage() const { return (2026 - year) > 25; }
};

class Message {
private:
    int MAX_LEN; // Removed const to allow assignment
    int msgID;
    string senderID;
    string receiverID;
    string content;
    bool isRead;

public:
    Message() : MAX_LEN(500), msgID(0), senderID(""), receiverID(""), content(""), isRead(false) {}
    Message(int id, string s, string r, string c) : MAX_LEN(500), msgID(id), senderID(s), receiverID(r), content(c), isRead(false) {}
    
    string getReceiver() const { return receiverID; }
    void setContent(string c) { content = c; }

    void deliver() { cout << "Delivered to " << receiverID << ".\n"; }
    void readMessage() { isRead = true; }
    void archive() { cout << "Archived.\n"; }
    void deleteMsg() { content = ""; }
};

class User {
protected:
    string userID;
    string name;
    string email;
    string password;
    Location userLoc;

public:
    User() {}
    User(string id, string n, string e, string p, Location l) : userID(id), name(n), email(e), password(p), userLoc(l) {}
    virtual ~User() {}

    string getName() const { return name; }
    void setEmail(string e) { email = e; }

    virtual void login(string p) { if(password == p) cout << "Logged in.\n"; }
    virtual void logout() { cout << "Logged out.\n"; }
    void resetPassword(string p) { password = p; }
    void updateProfile() { cout << "Profile updated.\n"; }
};

class Seller : public User {
private:
    int rating;
    int totalSold;
    string cnic;
    bool isVerified;
    string dealershipName;

public:
    Seller() : rating(0), totalSold(0), isVerified(false) {}
    Seller(string id, string n, string e, string p, Location l, string c, string d) 
        : User(id, n, e, p, l), rating(5), totalSold(0), cnic(c), isVerified(false), dealershipName(d) {}
    
    int getRating() const { return rating; }
